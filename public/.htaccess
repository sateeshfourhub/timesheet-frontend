<IfModule mod_rewrite.c>
  RewriteEngine On

  # Redirect www → apex (production only; no effect on subdomains)
  RewriteCond %{HTTP_HOST} ^www\.timekeepinghub\.com$ [NC]
  RewriteRule ^(.*)$ https://timekeepinghub.com/$1 [R=301,L]

  RewriteBase /
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>
